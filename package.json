{
  "name": "astrotracker",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop-first astrophotography data catalog (pnpm monorepo root)",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r build",
    "lint": "pnpm run lint:root && pnpm -r lint",
    "lint:root": "eslint eslint.config.mjs vitest.config.ts && prettier --check .",
    "test": "vitest run",
    "format": "prettier --write .",
    "fixtures:generate": "pnpm --filter @astrotracker/fixtures run generate"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  }
}
