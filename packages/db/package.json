{
  "name": "@astrotracker/db",
  "version": "0.1.0",
  "private": true,
  "description": "AstroTracker persistence layer — Drizzle schema, migrations, repositories (from P0-04)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src && prettier --check src",
    "test": "vitest run --dir src",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@astrotracker/core": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.4"
  }
}
