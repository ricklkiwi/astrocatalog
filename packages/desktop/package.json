{
  "name": "@astrotracker/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AstroTracker Electron main process shell (Electron runtime lands in P0-03)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src && prettier --check src",
    "test": "vitest run --dir src"
  },
  "dependencies": {
    "@astrotracker/core": "workspace:*",
    "@astrotracker/db": "workspace:*"
  }
}
