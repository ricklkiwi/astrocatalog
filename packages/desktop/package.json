{
  "name": "@astrotracker/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AstroTracker Electron app — main process, preload, typed IPC contract",
  "type": "module",
  "main": "./out/main/index.js",
  "types": "./src/ipc/contract.ts",
  "exports": {
    ".": {
      "types": "./src/ipc/contract.ts",
      "default": "./out/main/index.js"
    }
  },
  "scripts": {
    "postinstall": "install-electron",
    "predev": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev --watch",
    "build": "tsc --noEmit -p tsconfig.json && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src electron.vite.config.ts && prettier --check src electron.vite.config.ts",
    "pretest": "pnpm rebuild better-sqlite3",
    "test": "vitest run --dir src"
  },
  "devDependencies": {
    "@astrotracker/core": "workspace:*",
    "@astrotracker/db": "workspace:*",
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.0.0",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "sharp": "^0.35.3"
  }
}
