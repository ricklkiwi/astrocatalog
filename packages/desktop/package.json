{
  "name": "@astrotracker/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AstroTracker Electron app — main process, preload, typed IPC contract",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src electron.vite.config.ts && prettier --check src electron.vite.config.ts",
    "test": "vitest run --dir src"
  },
  "dependencies": {
    "@astrotracker/core": "workspace:*",
    "@astrotracker/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.6"
  }
}
