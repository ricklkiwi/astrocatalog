      "file": "fits/sgpro/sgpro-light-precision-timestamps.fits",
      "format": "fits",
      "description": "SGPro light frame whose DATE-OBS/DATE-LOC carry seven fractional digits (2023-05-25T06:45:26.0000000) - the documented SGPro timestamp shape.",
      "provenance": {
        "method": "synthesized-to-conventions",
        "program": "SGPro",
        "emulatesVersion": "4.x",
        "sources": [
          "https://www.sequencegeneratorpro.com/",
